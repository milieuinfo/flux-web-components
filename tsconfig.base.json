{
    "compilerOptions": {
        "baseUrl": ".",
        "outDir": "./build/tmp",
        "rootDirs": [
            "./libs",
            "./apps",
            "./resources"
        ],
        "types": [
            "cypress",
            "cypress-axe"
        ],
        "paths": {
            "@resources/utils-storybook": [
                "resources/utils-storybook/index.ts"
            ],
            "@resources/utils-test": [
                "resources/utils-test/index.ts"
            ],
            "@domg-wc/common": [
                "libs/common/src/index.ts"
            ],
            "@domg-wc/components/atom": [
                "libs/components/src/atom/index.ts"
            ],
            "@domg-wc/components/block": [
                "libs/components/src/block/index.ts"
            ],
            "@domg-wc/components/compliance": [
                "libs/components/src/compliance/index.ts"
            ],
            "@domg-wc/components/form": [
                "libs/components/src/form/index.ts"
            ],
            "@domg-wc/integrations/form": [
                "libs/integrations/src/form/index.ts"
            ],
            "@domg-wc/integrations/map": [
                "libs/integrations/src/map/index.ts"
            ],
            "@domg-wc/integrations/popover": [
                "libs/integrations/src/popover/index.ts"
            ],
			"@domg-wc/integrations/page-layout": [
				"libs/integrations/src/page-layout/index.ts"
			],
            "@domg-wc/map": [
                "libs/map/src/index.ts"
            ],
            "@domg-wc/styles": [
                "libs/styles/src/index.ts"
            ]
        },
        "target": "es2021",
        "moduleResolution": "node",
        "sourceMap": true,
        "inlineSources": true,
        "declaration": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "skipDefaultLibCheck": true
    }
}
