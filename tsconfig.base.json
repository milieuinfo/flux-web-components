{
    "compilerOptions": {
        "baseUrl": ".",
        "outDir": "./build/tmp",
        "rootDirs": ["./libs", "./apps", "./resources"],
        "types": ["cypress", "cypress-axe"],
        "paths": {
            "@resources/utils-storybook": ["resources/utils-storybook/stories.helper.ts"],
            "@domg-wc/common": ["libs/common/src/index.ts"],
            "@domg-wc/common/constants": ["libs/common/src/constants/index.ts"],
            "@domg-wc/components": ["libs/components/src/index.ts"],
            "@domg-wc/form": ["libs/form/src/index.ts"],
            "@domg-wc/integration/*": ["libs/integration/src/*"],
            "@domg-wc/map": ["libs/map/src/index.ts"],
            "@domg-wc/sections": ["libs/sections/src/index.ts"],
            "@domg-wc/styles": ["libs/styles/src/index.ts"]
        },
        "target": "es2021",
        "moduleResolution": "node",
        "sourceMap": true,
        "inlineSources": true,
        "declaration": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "skipDefaultLibCheck": true
    }
}
