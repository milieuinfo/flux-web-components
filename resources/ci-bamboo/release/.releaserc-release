{
    "branches": [
        "release-v2",
        "release-v2-2.15"
    ],
    "plugins": [
        [
            "@semantic-release/commit-analyzer",
            {
                "preset": "conventionalcommits"
            }
        ],
        "@semantic-release/release-notes-generator",
        [
            "@semantic-release/changelog",
            {
                "changelogFile": "resources/changelog/CHANGELOG.md"
            }
        ],
        [
            "@semantic-release/npm",
            {
                "npmPublish": false
            }
        ],
        [
            "@semantic-release/git",
            {
                "assets":
                [
                    "resources/changelog/CHANGELOG.md",
                    "package.json",
                    "package-lock.json",
                    "libs/components/src/atom/atom.web-types.json",
                    "libs/components/src/block/block.web-types.json",
                    "libs/components/src/compliance/compliance.web-types.json",
                    "libs/components/src/form/form.web-types.json",
                    "libs/map/map.web-types.json"
                ],
                "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
            }
        ],
        [
            "@semantic-release/github"
        ]
    ]
}
