                            "description": "Beeldt de button af als een ghost button.",
                            "default": "false"
                        },
                        {
                            "name": "loading",
                            "description": "Beeldt de button af als een loading button.<br/>We raden aan dit enkel te gebruiken voor primary buttons.",
                            "default": "false"
                        },
                        {
                            "name": "icon",
                            "description": "Beeldt een icoon af in de button.<br/>Standaard wordt dit icoon voor de tekst afgebeeld.",
                            "default": ""
                        },
                        {
                            "name": "icon-placement",
                            "description": "De positie van het icoon ten opzichte van de tekst.<br>Voegt margin toe tussen het icoon en de tekst.",
                            "value": {
                                "kind": "plain",
                                "type": "'before' | 'after'"
                            },
                            "default": "before"
